{
  "name": "@orderly.network/fast-place-order-plugin",
  "version": "0.1.1-alpha.0",
  "description": "Orderly SDK plugin — fast-place-order",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup && cp -r src/i18n/locales dist/locales && pnpm build-tailwind",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-tailwind": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@orderly.network/core": "3.0.1",
    "@orderly.network/hooks": "3.0.1",
    "@orderly.network/i18n": "3.0.1",
    "@orderly.network/plugin-core": "3.0.1",
    "@orderly.network/types": "3.0.1",
    "@orderly.network/ui": "3.0.1",
    "@orderly.network/ui-scaffold": "3.0.1",
    "@orderly.network/utils": "3.0.1",
    "@orderly.network/wallet-connector-privy": "3.0.1",
    "@solana-mobile/wallet-adapter-mobile": "^2.2.6",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@orderly.network/react-app": "3.0.1",
    "@orderly.network/trading": "3.0.1",
    "@orderly.network/ui-scaffold": "3.0.1",
    "@storybook/react-vite": "^10.3.1",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.3.1",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.6",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
